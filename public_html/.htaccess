##RewriteRule ^latam/(.*)$ "https://excel-facil.com/"
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301,NE]

# ─── SECURITY HEADERS ───
<IfModule mod_headers.c>
  Header always set Content-Security-Policy "upgrade-insecure-requests;"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(self)"
  # Ocultar banner del servidor
  Header unset X-Powered-By
  Header unset Server
</IfModule>

# ─── BLOQUEO DE ARCHIVOS SENSIBLES / LEGACY / BACKUPS ───
# Estos patrones cubren backups viejos, copias manuales y checkouts legacy que
# se descubrieron en el pentest y que ampliaban la superficie de ataque.
<FilesMatch "(?i)(^|/)(\.env|\.git.*|composer\.(json|lock)|package(-lock)?\.json|Dockerfile|nixpacks\.toml|entrypoint\.sh|.*\.(sql|bak|old|backup|swp|log|ini)|.*-ORIGINAL-.*\.php|.*-viejo\.php|.*_viejo\.php|.* copia\.php|.*-copia\.php|.*_copia\.php|test\.php|desactivado-.*\.php|checkout_1\.php|checkout_n\.php|checkout_n_c\.php)$">
  Require all denied
</FilesMatch>

# Bloquear acceso directo a panel phpmyadmin si quedara servido vía Apache.
# (Idealmente debería borrarse por completo del webroot — ver phpmyadmin/.htaccess)
RedirectMatch 403 (?i)^/phpmyadmin(/.*)?$

# Bloquear acceso al directorio Basura y archivos descartados
RedirectMatch 403 (?i)^/(Basura|archivos-sin-uso|railway-fixes)(/.*)?$

# Evitar listado de directorios
Options -Indexes

# ─── GZIP COMPRESSION ───
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
  AddOutputFilterByType DEFLATE application/json application/xml application/xhtml+xml
  AddOutputFilterByType DEFLATE font/woff font/woff2 application/font-woff application/font-woff2
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ─── BROWSER CACHING ───
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"

  # CSS & JS
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"

  # Images
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Fonts
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"

  # HTML (short cache - content changes)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ─── CACHE-CONTROL HEADERS ───
<IfModule mod_headers.c>
  # Static assets: cache 1 year
  <FilesMatch "\.(css|js|woff|woff2|ttf|eot|ico|jpg|jpeg|png|gif|webp|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML/PHP: no cache (dynamic content)
  <FilesMatch "\.(html|php)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# ─── KEEP-ALIVE ───
<IfModule mod_headers.c>
  Header set Connection keep-alive
</IfModule>

# ─── ETAG (disable - Expires is enough) ───
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None

# php -- BEGIN cPanel-generated handler, do not edit
# Set the “ea-php74” package as the default “PHP” programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php74___lsphp .php .php7 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
